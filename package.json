{
  "name": "onehealthcard",
  "version": "1.0.0",
  "description": "OneHealthCard - Digital Health Card Platform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "vercel-build": "npm install && npm run build --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
